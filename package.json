{
  "name": "workflow-manager",
  "version": "0.1.0",
  "description": "CLI runner for in-memory and markdown workflow orchestration using ATEP-like envelopes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workflow-manager": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "docs:dev": "vitepress dev doc",
    "docs:build": "vitepress build doc",
    "docs:preview": "vitepress preview doc"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "cli",
    "atep"
  ],
  "license": "MIT",
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.8"
  }
}
