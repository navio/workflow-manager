{
  "name": "workflow-manager",
  "version": "0.1.0",
  "description": "CLI runner for in-memory and markdown workflow orchestration using ATEP-like envelopes",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workflow-manager": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bin": "bun build ./src/index.ts --compile --outfile ./dist/workflow-manager",
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "docs:dev": "vitepress dev doc",
    "docs:build": "vitepress build doc",
    "docs:preview": "vitepress preview doc"
  },
  "keywords": [
    "workflow",
    "orchestration",
    "cli",
    "atep"
  ],
  "license": "MIT",
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.2",
    "vitepress": "^1.5.0"
  }
}
